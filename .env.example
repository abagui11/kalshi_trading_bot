# --- LLM ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Telegram (NEW bot only — do not reuse the spot bot token) ---
TELEGRAM_BOT_TOKEN=
PAYWALL_ENABLED=true
ALLOWED_TELEGRAM_IDS=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
MONITOR_CHAT_ID=
DASHBOARD_PUBLIC_URL=
DASHBOARD_PORT=8081

# --- Spot underlying (Coinbase public; used for direction context) ---
MARKET_DATA_API=https://api.coinbase.com/api/v3/brokerage/market

# --- Paper bankroll (house book) ---
PORTFOLIO_VALUE=1000
PAPER_PORTFOLIO_VALUE=1000

# --- Kalshi (paper first; prod key OK if KALSHI_PAPER_ONLY=true) ---
# Paper soak: keep PAPER_ONLY=true. Live orders later: set false + tiny MAX_CONTRACTS.
KALSHI_ENV=prod
KALSHI_API_BASE=https://external-api.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=secrets/kalshi_prod.key
KALSHI_SERIES=KXBTC15M,KXETH15M
KALSHI_PAPER_ONLY=true
KALSHI_MAX_CONTRACTS=5
KALSHI_MIN_EDGE_CENTS=3
KALSHI_CYCLE_OFFSET_SEC=30
